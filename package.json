{
  "name": "@tradik/xslt-processor",
  "version": "1.0.3",
  "description": "JavaScript implementation of XSLTProcessor for browser environments and CLI",
  "type": "module",
  "main": "dist/xslt-processor.cjs",
  "module": "dist/xslt-processor.js",
  "browser": "dist/xslt-processor.browser.js",
  "types": "dist/xslt-processor.d.ts",
  "bin": {
    "xslt": "./bin/xslt.js"
  },
  "exports": {
    ".": {
      "types": "./dist/xslt-processor.d.ts",
      "browser": "./dist/xslt-processor.browser.js",
      "import": "./dist/xslt-processor.js",
      "require": "./dist/xslt-processor.cjs"
    }
  },
  "files": [
    "dist",
    "src",
    "bin"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node scripts/build.js",
    "test": "node --test --experimental-test-coverage src/*.test.js src/**/*.test.js",
    "test:watch": "node --test --watch src/**/*.test.js",
    "test:browser": "node tests/browser-test-runner.js",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.js\"",
    "format:check": "prettier --check \"src/**/*.js\"",
    "prepublishOnly": "npm run build && npm run test"
  },
  "keywords": [
    "xslt",
    "xsltprocessor",
    "xml",
    "xpath",
    "transform",
    "browser",
    "w3c",
    "javascript"
  ],
  "author": "tradik",
  "license": "BSD-3-Clause",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/spagu/XSLT-Processor.git"
  },
  "bugs": {
    "url": "https://github.com/spagu/XSLT-Processor/issues"
  },
  "homepage": "https://github.com/spagu/XSLT-Processor#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "eslint": "^9.0.0",
    "prettier": "^3.4.0",
    "esbuild": "^0.28.1",
    "jsdom": "^25.0.0"
  }
}
